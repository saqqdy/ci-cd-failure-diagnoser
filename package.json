{
	"name": "ci-cd-failure-diagnoser",
	"description": "AI-powered CI/CD failure diagnoser — reads CI logs, identifies root causes, generates fix suggestions via Claude Code Skill",
	"version": "0.1.0-alpha.1",
	"packageManager": "pnpm@9.15.9",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"require": "./dist/index.js",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist",
		".claude"
	],
	"scripts": {
		"build": "run-s clean build:bundle build:types",
		"build:bundle": "tsup",
		"build:types": "tsc --emitDeclarationOnly",
		"clean": "rm-all dist",
		"dev": "tsup --watch",
		"lint": "eslint --fix .",
		"prettier": "prettier --write \"**/*.{js,ts,mjs,yml,json,md}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"dist": "run-s lint build",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@eslint-sets/eslint-config": "^6.3.1",
		"@types/node": "^26.0.0",
		"eslint": "^9.39.4",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.4",
		"prettier-config-common": "^1.5.0",
		"rm-all": "^1.1.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.6"
	},
	"engines": {
		"node": ">=18"
	},
	"keywords": [
		"claude-code",
		"skill",
		"ci-cd",
		"failure-diagnosis",
		"log-analysis",
		"github-actions",
		"gitlab-ci",
		"jenkins",
		"ai"
	],
	"author": "saqqdy",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/saqqdy/ci-cd-failure-diagnoser"
	}
}